{
  "id": "listen-mode",
  "name": "Listen Mode",
  "description": "Empathic listening mode plugin - pauses AI responses to let users express themselves fully before responding",
  "version": "0.1.2",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "triggerMode": {
        "type": "string",
        "enum": ["manual", "auto", "both"],
        "default": "manual"
      },
      "silenceTimeoutMs": {
        "type": "number",
        "default": 30000
      },
      "maxListenTimeMs": {
        "type": "number",
        "default": 120000
      },
      "maxBufferMessages": {
        "type": "integer",
        "default": 20
      },
      "sensitivity": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "default": "medium"
      },
      "languages": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["zh", "en"]
      },
      "systemHint": {
        "type": "boolean",
        "default": true
      },
      "ack": {
        "type": "object",
        "properties": {
          "entryReply": { "type": "boolean", "default": true },
          "intervalMessages": { "type": "array", "items": { "type": "integer" } },
          "intervalMs": { "type": "array", "items": { "type": "number" } },
          "useLLM": { "type": "boolean", "default": true },
          "llmModel": { "type": "string", "default": "haiku" },
          "llmTimeoutMs": { "type": "number", "default": 2000 }
        }
      },
      "reply": {
        "type": "object",
        "properties": {
          "splitEnabled": { "type": "boolean", "default": true },
          "maxCharsPerMessage": { "type": "integer", "default": 50 },
          "delayBaseMs": { "type": "number", "default": 1500 },
          "delayPerCharMs": { "type": "number", "default": 150 },
          "delayRandomMs": { "type": "number", "default": 1000 }
        }
      },
      "emoji": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "frequency": { "type": "string", "enum": ["low", "moderate", "high"], "default": "moderate" },
          "stickerEnabled": { "type": "boolean", "default": false },
          "stickerDir": { "type": "string" }
        }
      },
      "byChannel": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
